# Зависимости и артефакты сборки
node_modules/
.vitepress/cache/
.vitepress/dist/
test-results/
analysis-results/
analysis/
\#/

# Системное, IDE и логи
.DS_Store
.idea/
.claude/settings.local.json
npm-debug.log*
*.log

# Материалы редактора в папках лекций и дополнений:
# публикуются (и коммитятся) только vitepress.md и его ресурсы (assets/).
# Черновики, заметки, транскрипты, видео и PDF живут только локально.
content/lectures/*/*
!content/lectures/*/vitepress.md
!content/lectures/*/assets/
!content/lectures/*/assets/**
!content/lectures/_template/
!content/lectures/_template/**
content/extras/*/*
!content/extras/*/vitepress.md
!content/extras/*/assets/
!content/extras/*/assets/**
!content/extras/_template/
!content/extras/_template/**
!content/extras/index/
!content/extras/index/vitepress.md
content/service-pages/*/*
!content/service-pages/*/vitepress.md
!content/service-pages/_internal/
!content/service-pages/_internal/**
/.lecture-tree/
output/pdf/
