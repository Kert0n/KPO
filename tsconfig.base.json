{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "vitepress/dist/client/theme-default/components/VPFlyout.vue": [
        "./.vitepress/types/vp-flyout.d.ts"
      ],
      "vitepress/dist/client/theme-default/components/VPSwitchAppearance.vue": [
        "./.vitepress/types/vp-switch-appearance.d.ts"
      ]
    },
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
