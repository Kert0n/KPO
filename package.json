{
  "name": "kpo-notes",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vitepress dev",
    "dev:host": "vitepress dev --host 0.0.0.0",
    "prebuild": "node .vitepress/scripts/assert-node-version.mjs && node .vitepress/scripts/assert-content-contract.mjs",
    "build": "vitepress build",
    "budgets:check": "node scripts/check-performance-budgets.mjs",
    "preview": "vitepress preview",
    "preview:host": "vitepress preview --host 0.0.0.0",
    "pretest": "node .vitepress/scripts/assert-node-version.mjs && npm run test:fixture-isolation",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage && node scripts/check-critical-coverage.mjs",
    "test:watch": "vitest",
    "test:fixture-isolation": "node scripts/check-test-fixture-isolation.mjs",
    "workflow:check": "node scripts/check-workflows.mjs",
    "pretest:ui": "node .vitepress/scripts/assert-node-version.mjs && npm run test:fixture-isolation",
    "test:ui": "playwright test",
    "test:characterization": "npm run build && npm run test:characterization:prebuilt",
    "test:characterization:prebuilt": "playwright test --config playwright.characterization.config.ts",
    "test:characterization:update-published": "node -e \"if(process.platform!=='linux'){throw new Error('Visual baselines must be updated on Linux')}\" && KPO_BASE_URL=https://kert0n.github.io/KPO/ playwright test --config playwright.characterization.config.ts --update-snapshots",
    "typecheck:vue": "vue-tsc -p tsconfig.app.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck": "npm run typecheck:vue && npm run typecheck:node && npm run typecheck:test",
    "architecture:check": "node --experimental-strip-types scripts/check-architecture-boundaries.mts",
    "content:check": "npm run content:check:links && npm run content:check:markdown",
    "content:check:links": "node --experimental-strip-types scripts/check-content-links.mts",
    "content:check:markdown": "node --experimental-strip-types scripts/check-content-markdown.mts",
    "kotlin:extract": "node --experimental-strip-types scripts/extract-kotlin-snippets.mts",
    "kotlin:check": "npm run kotlin:extract && ./gradlew compileKotlin --no-daemon",
    "lint": "eslint . --max-warnings=0 && npm run architecture:check",
    "format:check": "prettier --check .",
    "format:check:tracked": "node scripts/check-tracked-format.mjs",
    "format": "prettier --write .",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run workflow:check && npm test && npm run audit && npm run content:check && npm run build",
    "verify:full": "npm run verify && npm run test:ui",
    "pdf": "npm run build && node scripts/export-pdf.mjs",
    "pdf:published": "KPO_PDF_BASE_URL=https://kert0n.github.io/KPO/ node scripts/export-pdf.mjs --remote"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "14.1.2",
    "@types/markdown-it-container": "2.0.10",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "gray-matter": "4.0.3",
    "markdown-it": "^14.3.0",
    "markdown-it-container": "4.0.0",
    "markdown-it-mathjax3": "^4.3.2",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.9.5",
    "shiki": "2.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitepress": "1.6.4",
    "vitest": "^4.1.9",
    "vue": "3.5.39",
    "vue-tsc": "^3.3.7"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "kotlin-playground": "1.34.0",
    "mermaid": "11.16.0"
  },
  "overrides": {
    "vitepress": {
      "vite": "6.4.3"
    }
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
