{
  "name": "kpo-notes",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vitepress dev",
    "dev:host": "vitepress dev --host 0.0.0.0",
    "prebuild": "node .vitepress/scripts/assert-node-version.mjs && node .vitepress/scripts/assert-content-contract.mjs",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "preview:host": "vitepress preview --host 0.0.0.0",
    "pretest": "node .vitepress/scripts/assert-node-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:ui": "node .vitepress/scripts/assert-node-version.mjs",
    "test:ui": "playwright test",
    "test:characterization": "npm run build && npm run test:characterization:prebuilt",
    "test:characterization:prebuilt": "playwright test --config playwright.characterization.config.ts",
    "test:characterization:update-published": "node -e \"if(process.platform!=='linux'){throw new Error('Visual baselines must be updated on Linux')}\" && KPO_BASE_URL=https://kert0n.github.io/KPO/ playwright test --config playwright.characterization.config.ts --update-snapshots",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate",
    "verify": "npm run typecheck && npm test && npm run audit && npm run build",
    "pdf": "npm run build && node scripts/export-pdf.mjs",
    "pdf:published": "KPO_PDF_BASE_URL=https://kert0n.github.io/KPO/ node scripts/export-pdf.mjs --remote"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "14.1.2",
    "@types/markdown-it-container": "2.0.10",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "gray-matter": "4.0.3",
    "markdown-it": "^14.3.0",
    "markdown-it-container": "4.0.0",
    "markdown-it-mathjax3": "^4.3.2",
    "pdf-lib": "^1.17.1",
    "shiki": "2.5.0",
    "typescript": "5.9.3",
    "vitepress": "1.6.4",
    "vitest": "^4.1.9",
    "vue": "3.5.39"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "kotlin-playground": "1.34.0",
    "mermaid": "11.16.0"
  },
  "overrides": {
    "vitepress": {
      "vite": "6.4.3"
    }
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
