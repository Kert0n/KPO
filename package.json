{
  "name": "kpo-notes",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vitepress dev",
    "dev:host": "vitepress dev --host 0.0.0.0",
    "prebuild": "node .vitepress/scripts/assert-node-version.mjs && node .vitepress/scripts/assert-content-contract.mjs",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "preview:host": "vitepress preview --host 0.0.0.0",
    "pretest": "node .vitepress/scripts/assert-node-version.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:ui": "node .vitepress/scripts/assert-node-version.mjs",
    "test:ui": "playwright test",
    "typecheck:vue": "vue-tsc --noEmit -p tsconfig.app.json",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck": "npm run typecheck:vue && npm run typecheck:node && npm run typecheck:test",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "validate:content": "node .vitepress/scripts/assert-content-contract.mjs && tsx scripts/validate-content.mts",
    "extract:playground": "tsx scripts/extract-playground-examples.mts",
    "validate:playground": "npm run extract:playground && ./tooling/kotlin-snippets/gradlew --no-daemon compileKotlin",
    "check:performance": "tsx scripts/check-performance-budget.mts",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --audit-level=moderate",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run validate:content && npm run test:coverage",
    "verify": "npm run check && npm run audit && npm run build && npm run check:performance && npm run validate:playground && npm run test:ui",
    "pdf": "npm run build && tsx scripts/export-pdf.mjs",
    "pdf:published": "tsx scripts/export-pdf.mjs --remote"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/markdown-it": "14.1.2",
    "@types/markdown-it-container": "2.0.10",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.5.0",
    "gray-matter": "4.0.3",
    "markdown-it": "^14.3.0",
    "markdown-it-container": "4.0.0",
    "markdown-it-mathjax3": "^4.3.2",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.9.5",
    "shiki": "2.5.0",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitepress": "1.6.4",
    "vitest": "^4.1.9",
    "vue": "3.5.39",
    "vue-tsc": "^3.3.7"
  },
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "kotlin-playground": "1.34.0",
    "mermaid": "11.16.0"
  },
  "overrides": {
    "vitepress": {
      "vite": "6.4.3"
    }
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
