{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "types": ["node", "vitepress/client"]
  },
  "include": [".vitepress/**/*.ts", ".vitepress/**/*.vue"]
}
