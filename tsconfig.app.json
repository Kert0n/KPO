{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.app.tsbuildinfo",
    "types": ["node", "vitepress/client"]
  },
  "include": [
    ".vitepress/theme/**/*.ts",
    ".vitepress/theme/**/*.vue",
    ".vitepress/theme/**/*.d.ts",
    ".vitepress/types/**/*.d.ts",
    ".vitepress/lib/**/*.ts",
    ".vitepress/markdown/**/*.ts"
  ],
  "exclude": [".vitepress/**/*.test.ts", ".vitepress/dist/**", ".vitepress/cache/**"]
}
